{
  "name": "asset-minify",
  "version": "1.0.3",
  "description": "A high-performance CLI tool to compress images, SVGs, and videos in-place for frontend projects.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "asset-minify": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "minify",
    "optimize",
    "compress",
    "image",
    "video",
    "svg",
    "nextjs",
    "frontend",
    "assets",
    "cli"
  ],
  "author": "Narottam Chy",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.0.0",
    "prompts": "^2.4.2",
    "sharp": "^0.33.2",
    "svgo": "^3.2.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@types/prompts": "^2.4.9",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  }
}
